# NVIDIA Nemotron API (REQUIRED)
# Get your free API key at: https://build.nvidia.com
# Free tier: 1,000 inference credits + 40 req/min
NVIDIA_API_KEY=nvapi-your-key-here

# Models (don't change unless NVIDIA updates)
SUPER_MODEL=nvidia/nemotron-3-super-120b-a12b
NANO_MODEL=nvidia/nemotron-3-nano-30b-a3b
NEMOTRON_BASE_URL=https://integrate.api.nvidia.com/v1

# App config
API_PORT=8000
WEB_PORT=3000
DATABASE_URL=sqlite+aiosqlite:///./codemigrator.db
LOG_LEVEL=INFO

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
